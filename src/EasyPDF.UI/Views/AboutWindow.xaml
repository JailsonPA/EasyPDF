<Window x:Class="EasyPDF.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About EasyPDF"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="360" Height="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />   <!-- title bar -->
            <RowDefinition Height="*" />    <!-- content -->
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowChromeBrush}"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock Text="About EasyPDF"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource WindowChromeTextBrush}"
                       VerticalAlignment="Center" Margin="12,0" />
            <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                    Style="{DynamicResource ChromeButtonStyle}"
                    Click="CloseClick" />
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Margin="0">

            <!-- App icon — PNG gives crisp rendering; ICO upscales and blurs -->
            <Image Source="pack://application:,,,/Assets/app-256.png"
                   Width="72" Height="72"
                   HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <!-- App name -->
            <TextBlock Text="EasyPDF"
                       FontSize="26" FontWeight="Light"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,12,0,2" />

            <!-- Version -->
            <TextBlock x:Name="VersionText"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />

            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

            <!-- Description -->
            <TextBlock Text="Fast, lightweight PDF viewer for Windows"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,16" />

            <!-- Creator -->
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Criado por"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Jailson Prazeres"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,2,0,4" />
                <TextBlock x:Name="CopyrightText"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
