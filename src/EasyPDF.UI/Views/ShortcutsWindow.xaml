<Window x:Class="EasyPDF.UI.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Shortcuts"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="KeyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Consolas, Courier New" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="DescText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowChromeBrush}"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock Text="Keyboard Shortcuts"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource WindowChromeTextBrush}"
                       VerticalAlignment="Center" Margin="12,0" />
            <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                    Style="{DynamicResource ChromeButtonStyle}"
                    Click="CloseClick" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,20">

                <!-- FILE -->
                <TextBlock Text="FILE" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+O"    Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Open PDF"  Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+W"    Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Close document / window" Style="{StaticResource DescText}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" />

                <!-- NAVIGATION -->
                <TextBlock Text="NAVIGATION" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="← / PageUp"   Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Previous page" Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="→ / PageDown"  Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Next page"     Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Home"          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="First page"    Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="End"           Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Last page"     Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+G"        Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Go to page"    Style="{StaticResource DescText}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" />

                <!-- ZOOM -->
                <TextBlock Text="ZOOM" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+scroll"  Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Smooth zoom"  Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl++"       Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Zoom in"      Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+−"       Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Zoom out"     Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+0"       Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Reset zoom"   Style="{StaticResource DescText}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" />

                <!-- SEARCH -->
                <TextBlock Text="SEARCH" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+F"         Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Find in document" Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="F3"             Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Next match"     Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Shift+F3"       Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Previous match" Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Esc"            Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Close search"   Style="{StaticResource DescText}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" />

                <!-- EDIT & DOCUMENT -->
                <TextBlock Text="EDIT &amp; DOCUMENT" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+C"          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Copy selected text" Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+B"          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Add bookmark"    Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+P"          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Print"           Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+["          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Rotate page left"  Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+]"          Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Rotate page right" Style="{StaticResource DescText}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,14" />

                <!-- VIEW -->
                <TextBlock Text="VIEW" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Alt+Enter"      Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="File properties" Style="{StaticResource DescText}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="F1"             Style="{StaticResource KeyText}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Show this help" Style="{StaticResource DescText}" />
                </Grid>

                <!-- Close button -->
                <Button Content="Close" Style="{DynamicResource AccentButtonStyle}"
                        HorizontalAlignment="Right" Margin="0,24,0,0"
                        Padding="20,6" Click="CloseClick" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
