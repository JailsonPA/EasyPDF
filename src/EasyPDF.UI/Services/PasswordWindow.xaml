<Window x:Class="EasyPDF.UI.Services.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Required"
        Width="380" Height="185"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        KeyDown="OnKeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File description -->
        <TextBlock x:Name="MessageText" Grid.Row="0"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4" />

        <!-- Error feedback (visible only after a wrong-password attempt) -->
        <TextBlock x:Name="ErrorText" Grid.Row="1"
                   FontSize="12" Foreground="#E53935"
                   Visibility="Collapsed" />

        <!-- Masked password entry -->
        <PasswordBox x:Name="PwdBox" Grid.Row="3" FontSize="13" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="75" Click="Cancel_Click" Margin="0,0,8,0"
                    Style="{DynamicResource ToolbarButtonStyle}" />
            <Button Content="OK" Width="75" Click="OK_Click"
                    Style="{DynamicResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
