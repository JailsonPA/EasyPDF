<Window x:Class="EasyPDF.UI.Views.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Properties"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowChromeBrush}"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock Text="File Properties"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource WindowChromeTextBrush}"
                       VerticalAlignment="Center" Margin="12,0" />
            <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                    Style="{DynamicResource ChromeButtonStyle}"
                    Click="CloseClick" />
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,20">

                <!-- GENERAL -->
                <TextBlock Text="GENERAL" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8" />
                    <TextBlock x:Name="NameValue" Grid.Row="0" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Location"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8"
                               VerticalAlignment="Top" />
                    <TextBlock x:Name="LocationValue" Grid.Row="1" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Size"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8" />
                    <TextBlock x:Name="SizeValue" Grid.Row="2" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="PDF version"
                               Style="{DynamicResource PropLabelStyle}" />
                    <TextBlock x:Name="PdfVersionValue" Grid.Row="3" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                <!-- DOCUMENT -->
                <TextBlock Text="DOCUMENT" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Pages"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8" />
                    <TextBlock x:Name="PagesValue" Grid.Row="0" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Page size"
                               Style="{DynamicResource PropLabelStyle}" />
                    <TextBlock x:Name="PageSizeValue" Grid.Row="1" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                <!-- SECURITY -->
                <TextBlock Text="SECURITY" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Encryption"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8" />
                    <TextBlock x:Name="EncryptionValue" Grid.Row="0" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Restrictions"
                               Style="{DynamicResource PropLabelStyle}" />
                    <TextBlock x:Name="RestrictionsValue" Grid.Row="1" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" />
                </Grid>

                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,16" />

                <!-- DATES -->
                <TextBlock Text="DATES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Last modified"
                               Style="{DynamicResource PropLabelStyle}" Margin="0,0,0,8" />
                    <TextBlock x:Name="LastModifiedValue" Grid.Row="0" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="File created"
                               Style="{DynamicResource PropLabelStyle}" />
                    <TextBlock x:Name="FileCreatedValue" Grid.Row="1" Grid.Column="1"
                               Style="{DynamicResource PropValueStyle}" />
                </Grid>

                <!-- Close button -->
                <Button Content="Close" Style="{DynamicResource AccentButtonStyle}"
                        HorizontalAlignment="Right" Margin="0,24,0,0"
                        Padding="20,6" Click="CloseClick" />

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Window.Resources>
        <Style x:Key="PropLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="PropValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </Window.Resources>
</Window>
