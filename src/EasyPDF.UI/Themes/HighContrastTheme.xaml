<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === Palette (Windows High Contrast Black) === -->
    <!-- Pure black background; white borders; yellow accent — all WCAG AAA compliant. -->
    <Color x:Key="BackgroundColor">#000000</Color>
    <Color x:Key="SurfaceColor">#000000</Color>
    <Color x:Key="SurfaceAltColor">#1C1C1C</Color>
    <Color x:Key="BorderColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#FFFF00</Color>
    <Color x:Key="AccentHoverColor">#FFF200</Color>
    <Color x:Key="AccentForegroundColor">#000000</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#CECECE</Color>
    <Color x:Key="TextDisabledColor">#6D6D6D</Color>
    <Color x:Key="ScrollThumbColor">#C0C0C0</Color>
    <Color x:Key="ScrollThumbHoverColor">#FFFF00</Color>
    <Color x:Key="ToolbarColor">#000000</Color>
    <Color x:Key="SidebarColor">#000000</Color>
    <Color x:Key="PageBackgroundColor">#1C1C1C</Color>
    <Color x:Key="SelectionColor">#1AEBFF</Color>
    <Color x:Key="SearchHighlightColor">#FFFF00</Color>

    <!-- === Brushes === -->
    <SolidColorBrush x:Key="BackgroundBrush"        Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush"        Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="BorderBrush"            Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush"            Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush"       Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentForegroundBrush"  Color="{StaticResource AccentForegroundColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush"      Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="ScrollThumbBrush"       Color="{StaticResource ScrollThumbColor}" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush"  Color="{StaticResource ScrollThumbHoverColor}" />
    <SolidColorBrush x:Key="ToolbarBrush"           Color="{StaticResource ToolbarColor}" />
    <SolidColorBrush x:Key="SidebarBrush"           Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="PageBackgroundBrush"    Color="{StaticResource PageBackgroundColor}" />
    <SolidColorBrush x:Key="SelectionBrush"         Color="{StaticResource SelectionColor}" />
    <SolidColorBrush x:Key="SearchHighlightBrush"   Color="{StaticResource SearchHighlightColor}" />

    <SolidColorBrush x:Key="ThumbnailSelectedBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="ThumbnailBorderBrush"   Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="WindowChromeBrush"      Color="#000000" />
    <SolidColorBrush x:Key="WindowChromeTextBrush"  Color="{StaticResource TextPrimaryColor}" />

</ResourceDictionary>
