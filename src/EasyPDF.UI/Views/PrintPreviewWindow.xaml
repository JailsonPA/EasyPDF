<Window x:Class="EasyPDF.UI.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyPDF.Application.ViewModels;assembly=EasyPDF.Application"
        xmlns:m="clr-namespace:EasyPDF.Application.Models;assembly=EasyPDF.Application"
        xmlns:conv="clr-namespace:EasyPDF.UI.Converters"
        WindowStyle="None"
        Width="900" Height="640"
        MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        Icon="pack://application:,,,/Assets/app.ico"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <conv:EnumEqualityConverter x:Key="EnumEqConv" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />

        <!-- RadioButton / CheckBox default templates use SystemColors-based foreground,
             which renders dark text on our dark theme (invisible). Override the label
             color so it follows the active theme. -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowChromeBrush}"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource WindowChromeTextBrush}"
                       VerticalAlignment="Center" Margin="12,0">
                <Run Text="Print preview — " />
                <Run Text="{Binding DocumentTitle, Mode=OneWay}" />
            </TextBlock>
            <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                    Style="{DynamicResource ChromeButtonStyle}"
                    Click="CloseClick" />
        </Grid>

        <!-- Body: left settings panel + right preview pane -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Settings -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16">
                    <StackPanel>

                        <TextBlock Text="PAGES" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />

                        <RadioButton GroupName="Range" Content="All pages" Margin="0,2"
                                     IsChecked="{Binding Range, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintRangeKind.AllPages}}" />
                        <RadioButton GroupName="Range" Content="Current page" Margin="0,2"
                                     IsChecked="{Binding Range, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintRangeKind.CurrentPage}}" />
                        <RadioButton GroupName="Range" Content="Odd pages only" Margin="0,2"
                                     IsChecked="{Binding Range, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintRangeKind.OddPagesOnly}}" />
                        <RadioButton GroupName="Range" Content="Even pages only" Margin="0,2"
                                     IsChecked="{Binding Range, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintRangeKind.EvenPagesOnly}}" />
                        <RadioButton x:Name="CustomRadio" GroupName="Range" Content="Custom range:" Margin="0,2,0,4"
                                     IsChecked="{Binding Range, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintRangeKind.CustomRange}}" />
                        <TextBox Text="{Binding CustomRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsChecked, ElementName=CustomRadio}"
                                 FontSize="12" Margin="0,0,0,4" Padding="6,4" />
                        <TextBlock Text="e.g. 1-3, 5, 7-9"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                        <TextBlock Text="{Binding SelectionSummary, Mode=OneWay}"
                                   FontSize="11" FontStyle="Italic" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,16" />

                        <TextBlock Text="SIZING" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />

                        <RadioButton GroupName="Fit" Content="Actual size" Margin="0,2"
                                     IsChecked="{Binding FitMode, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintFitMode.Actual}}" />
                        <RadioButton GroupName="Fit" Content="Shrink to printable area" Margin="0,2"
                                     IsChecked="{Binding FitMode, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintFitMode.ShrinkToFit}}" />
                        <RadioButton GroupName="Fit" Content="Fit to page" Margin="0,2"
                                     IsChecked="{Binding FitMode, Mode=TwoWay,
                                                 Converter={StaticResource EnumEqConv},
                                                 ConverterParameter={x:Static m:PrintFitMode.FitToPage}}" />

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,16" />

                        <TextBlock Text="ANNOTATIONS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                        <CheckBox Content="Include highlights / underlines"
                                  IsChecked="{Binding IncludeAnnotations, Mode=TwoWay}" />

                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,16" />

                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            Printer, copies, duplex and color settings are selected in the next dialog (after you click Print).
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Preview pane -->
            <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Nav strip -->
                <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                Style="{DynamicResource Mdl2IconButtonStyle}"
                                Command="{Binding PrevPreviewCommand}" Margin="2,0" />
                        <TextBlock Text="{Binding CurrentPreviewDisplay, Mode=OneWay}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Margin="12,0" MinWidth="160" TextAlignment="Center" />
                        <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                Style="{DynamicResource Mdl2IconButtonStyle}"
                                Command="{Binding NextPreviewCommand}" Margin="2,0" />
                    </StackPanel>
                </Border>

                <!-- The image itself -->
                <Grid Grid.Row="1" Margin="24">
                    <Border Background="White"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="3" BlurRadius="14" Opacity="0.35" Color="Black" />
                        </Border.Effect>
                        <Image Source="{Binding PreviewImage}"
                               MaxHeight="500" MaxWidth="420"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="Fant" />
                    </Border>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsRenderingPreview, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#x231B;" FontSize="32"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Rendering preview…"
                                   FontSize="11" Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- Footer with Print / Cancel -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,18,0">
                <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        Click="CloseClick" />
                <Button Content="Print…" Width="100"
                        Style="{DynamicResource AccentButtonStyle}"
                        Command="{Binding ConfirmPrintCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
