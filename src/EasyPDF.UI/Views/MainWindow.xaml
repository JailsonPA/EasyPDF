<Window x:Class="EasyPDF.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyPDF.Application.ViewModels;assembly=EasyPDF.Application"
        xmlns:views="clr-namespace:EasyPDF.UI.Views"
        xmlns:conv="clr-namespace:EasyPDF.UI.Converters"
        xmlns:bhv="clr-namespace:EasyPDF.UI.Behaviors"
        xmlns:h="clr-namespace:EasyPDF.UI.Helpers"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:core="clr-namespace:EasyPDF.Core.Models;assembly=EasyPDF.Core"
        Title="{Binding Title}"
        Icon="pack://application:,,,/Assets/app.ico"
        MinWidth="900" MinHeight="600"
        Width="1280" Height="800"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EnumEqualityConverter x:Key="EnumEqConv" />
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis"
                                        TrueValue="Collapsed" FalseValue="Visible" />
        <conv:InverseBoolConverter x:Key="InvBool" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True" />
        <conv:ZoomToPercentConverter x:Key="ZoomConv" />
        <conv:OneBasedIndexConverter x:Key="PageConv" />

        <!-- Tab activate button: slim, shows accent bottom-border when active -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab close (×) button -->
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Suppresses the Windows 11 DWM snap-bar handle (white pill at top-center) on borderless windows. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <i:Interaction.Behaviors>
        <bhv:FileDragDropBehavior />
    </i:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />   <!-- 0: Toolbar (also acts as title bar — drag + chrome) -->
            <RowDefinition Height="Auto" /> <!-- 1: Tab strip -->
            <RowDefinition Height="Auto" /> <!-- 2: Update banner -->
            <RowDefinition Height="Auto" /> <!-- 3: File changed banner -->
            <RowDefinition Height="Auto" /> <!-- 4: Search panel -->
            <RowDefinition Height="Auto" /> <!-- 5: Edit toolbar -->
            <RowDefinition Height="*" />    <!-- 6: Main content -->
            <RowDefinition Height="24" />   <!-- 7: Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== Toolbar (also acts as title bar — drag region + window chrome buttons) ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Brand + Menu bar -->
                    <ColumnDefinition Width="*" />     <!-- Page nav -->
                    <ColumnDefinition Width="Auto" />  <!-- Zoom (out / level / in) -->
                    <ColumnDefinition Width="Auto" />  <!-- Window chrome (Min/Max/Close) -->
                </Grid.ColumnDefinitions>

                <!-- Left: brand + application menu -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <!--   <Image Source="pack://application:,,,/Assets/app-256.png"
                           Width="20" Height="20" Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="EasyPDF" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Separator Style="{DynamicResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Width="1" Height="16" Margin="0,0,4,0" /> -->

                    <!-- Sidebar toggle — kept inline as a quick-action (also in View menu) -->
                    <Button Content="&#xE700;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="0,0,4,0"
                            AutomationProperties.Name="Toggle sidebar"
                            h:Tip.Title="Toggle sidebar"
                            Command="{Binding Sidebar.ToggleVisibilityCommand}" />

                    <!-- Application menu (commands grouped: File / Edit / View / Tools / Help) -->
                    <Menu Background="Transparent" BorderThickness="0" Padding="0"
                          VerticalAlignment="Stretch"
                          Foreground="{DynamicResource TextSecondaryBrush}">
                        <Menu.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </Menu.ItemsPanel>

                        <MenuItem Header="_File" Style="{StaticResource TopBarMenuItemStyle}">
                            <MenuItem Header="_Open PDF..." Command="{Binding OpenFileCommand}"
                                      InputGestureText="Ctrl+O" />
                            <Separator />
                            <MenuItem Header="Show in _Explorer"
                                      Command="{Binding OpenInExplorerCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="_Properties" InputGestureText="Alt+Enter"
                                      Click="PropertiesClick"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="_Print..." Command="{Binding PrintCommand}"
                                      InputGestureText="Ctrl+P"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="Export Page as _Image..."
                                      Command="{Binding ExportCurrentPageCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="Export _Annotated PDF..."
                                      Command="{Binding ExportAnnotatedPdfCommand}"
                                      InputGestureText="Ctrl+Shift+E"
                                      IsEnabled="{Binding HasDocument}"
                                      ToolTip="Rasterizes every page as image and bakes annotations into the pixels. Best for sharing where the receiver may not have an annotation-capable reader." />
                            <MenuItem Header="_Save Annotations to PDF..."
                                      Command="{Binding SaveAnnotationsToPdfCommand}"
                                      IsEnabled="{Binding HasDocument}"
                                      ToolTip="Preserves the original PDF (selectable text + vectors) and writes annotations as native PDF objects. Best for sharing with users of Adobe / Foxit / other PDF readers." />
                            <Separator />
                            <MenuItem Header="E_xit" Click="CloseClick" />
                        </MenuItem>

                        <MenuItem Header="_Edit" Style="{StaticResource TopBarMenuItemStyle}">
                            <MenuItem Header="_Undo"
                                      Command="{Binding UndoCommand}"
                                      InputGestureText="Ctrl+Z" />
                            <MenuItem Header="_Redo"
                                      Command="{Binding RedoCommand}"
                                      InputGestureText="Ctrl+Y" />
                            <Separator />
                            <MenuItem Header="_Find" Command="{Binding ToggleSearchCommand}"
                                      InputGestureText="Ctrl+F"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <!-- Highlight currently-selected text (mirror of right-click → Highlight). Select text on the page first. -->
                            <MenuItem Header="_Highlight Selection" IsEnabled="{Binding HasDocument}">
                                <MenuItem Header="_Yellow"
                                          Command="{Binding Viewer.HighlightSelectionCommand}"
                                          CommandParameter="Yellow" />
                                <MenuItem Header="_Green"
                                          Command="{Binding Viewer.HighlightSelectionCommand}"
                                          CommandParameter="Green" />
                                <MenuItem Header="_Pink"
                                          Command="{Binding Viewer.HighlightSelectionCommand}"
                                          CommandParameter="Pink" />
                                <MenuItem Header="_Blue"
                                          Command="{Binding Viewer.HighlightSelectionCommand}"
                                          CommandParameter="Blue" />
                                <MenuItem Header="_Red"
                                          Command="{Binding Viewer.HighlightSelectionCommand}"
                                          CommandParameter="Red" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_Annotation Mode" IsEnabled="{Binding HasDocument}">
                                <MenuItem Header="_Note" IsCheckable="True"
                                          Command="{Binding Viewer.SetEditModeCommand}"
                                          CommandParameter="{x:Static vm:EditMode.Note}"
                                          IsChecked="{Binding Viewer.CurrentEditMode,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=Note, Mode=OneWay}" />
                                <MenuItem Header="_Draw (Ink)" IsCheckable="True"
                                          Command="{Binding Viewer.SetEditModeCommand}"
                                          CommandParameter="{x:Static vm:EditMode.Ink}"
                                          IsChecked="{Binding Viewer.CurrentEditMode,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=Ink, Mode=OneWay}" />
                                <MenuItem Header="_Eraser" IsCheckable="True"
                                          Command="{Binding Viewer.SetEditModeCommand}"
                                          CommandParameter="{x:Static vm:EditMode.Eraser}"
                                          IsChecked="{Binding Viewer.CurrentEditMode,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=Eraser, Mode=OneWay}" />
                            </MenuItem>
                            <MenuItem Header="_Color (Ink)" IsEnabled="{Binding HasDocument}">
                                <MenuItem Header="_Blue" IsCheckable="True"
                                          Command="{Binding Viewer.SetInkColorCommand}"
                                          CommandParameter="#FF2563EB"
                                          IsChecked="{Binding Viewer.InkColor,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=#FF2563EB, Mode=OneWay}" />
                                <MenuItem Header="_Red" IsCheckable="True"
                                          Command="{Binding Viewer.SetInkColorCommand}"
                                          CommandParameter="#FFDC2626"
                                          IsChecked="{Binding Viewer.InkColor,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=#FFDC2626, Mode=OneWay}" />
                                <MenuItem Header="Bla_ck" IsCheckable="True"
                                          Command="{Binding Viewer.SetInkColorCommand}"
                                          CommandParameter="#FF1A1A1A"
                                          IsChecked="{Binding Viewer.InkColor,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=#FF1A1A1A, Mode=OneWay}" />
                                <MenuItem Header="_Green" IsCheckable="True"
                                          Command="{Binding Viewer.SetInkColorCommand}"
                                          CommandParameter="#FF16A34A"
                                          IsChecked="{Binding Viewer.InkColor,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=#FF16A34A, Mode=OneWay}" />
                                <MenuItem Header="_Orange" IsCheckable="True"
                                          Command="{Binding Viewer.SetInkColorCommand}"
                                          CommandParameter="#FFEA580C"
                                          IsChecked="{Binding Viewer.InkColor,
                                                      Converter={StaticResource EnumEqConv},
                                                      ConverterParameter=#FFEA580C, Mode=OneWay}" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Add _Bookmark" Command="{Binding AddBookmarkCommand}"
                                      InputGestureText="Ctrl+B"
                                      IsEnabled="{Binding HasDocument}" />
                        </MenuItem>

                        <MenuItem Header="_View" Style="{StaticResource TopBarMenuItemStyle}">
                            <MenuItem Header="Zoom _In" Command="{Binding Viewer.ZoomInCommand}"
                                      InputGestureText="Ctrl++"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="Zoom _Out" Command="{Binding Viewer.ZoomOutCommand}"
                                      InputGestureText="Ctrl+−"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="_Reset Zoom" Command="{Binding Viewer.ResetZoomCommand}"
                                      InputGestureText="Ctrl+0"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="Fit to _Width" Command="{Binding Viewer.FitToWidthModeCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="Fit to _Page" Command="{Binding Viewer.FitToPageModeCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="_First Page" Command="{Binding Viewer.FirstPageCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="_Last Page" Command="{Binding Viewer.LastPageCommand}"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="Rotate _Left"
                                      Command="{Binding Viewer.RotateCurrentPageCounterClockwiseCommand}"
                                      InputGestureText="Ctrl+["
                                      IsEnabled="{Binding HasDocument}" />
                            <MenuItem Header="Rotate Ri_ght"
                                      Command="{Binding Viewer.RotateCurrentPageClockwiseCommand}"
                                      InputGestureText="Ctrl+]"
                                      IsEnabled="{Binding HasDocument}" />
                            <Separator />
                            <MenuItem Header="Toggle _Sidebar"
                                      Command="{Binding Sidebar.ToggleVisibilityCommand}" />
                        </MenuItem>

                        <MenuItem Header="_Tools" Style="{StaticResource TopBarMenuItemStyle}">
                            <MenuItem Header="Cycle _Theme" Command="{Binding ToggleThemeCommand}"
                                      ToolTip="Dark · Light · High Contrast" />
                        </MenuItem>

                        <MenuItem Header="_Help" Style="{StaticResource TopBarMenuItemStyle}">
                            <MenuItem Header="_Keyboard Shortcuts" Click="ShortcutsClick"
                                      InputGestureText="F1" />
                            <Separator />
                            <MenuItem Header="_About EasyPDF" Click="AboutClick" />
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Centre: page navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">

                    <Button Content="&#xE892;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="2,0"
                            AutomationProperties.Name="First page"
                            Command="{Binding Viewer.FirstPageCommand}" h:Tip.Title="First page" />
                    <Button Content="&#xE76B;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="2,0"
                            AutomationProperties.Name="Previous page"
                            Command="{Binding Viewer.PreviousPageCommand}"
                            h:Tip.Title="Previous page" h:Tip.Keys="← · PageUp" />

                    <Border Background="{DynamicResource SurfaceAltBrush}" Margin="4,0"
                            CornerRadius="4" Padding="4,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="PageInputBox"
                                     AutomationProperties.Name="Page number"
                                     Width="36" FontSize="12"
                                     h:Tip.Title="Go to page"
                                     h:Tip.Keys="Ctrl+G  ·  Enter to navigate"
                                     Text="{Binding Viewer.CurrentPageIndex, Converter={StaticResource PageConv},
                                                    UpdateSourceTrigger=LostFocus}"
                                     VerticalContentAlignment="Center"
                                     TextAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     KeyDown="PageInputKeyDown" />
                            <TextBlock FontSize="12" Margin="2,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="/" />
                                <Run Text="{Binding Viewer.PageCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Button Content="&#xE76C;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="2,0"
                            AutomationProperties.Name="Next page"
                            Command="{Binding Viewer.NextPageCommand}"
                            h:Tip.Title="Next page" h:Tip.Keys="→ · PageDown" />
                    <Button Content="&#xE893;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="2,0"
                            AutomationProperties.Name="Last page"
                            Command="{Binding Viewer.LastPageCommand}" h:Tip.Title="Last page" />
                </StackPanel>

                <!-- Right: zoom + bookmark + search + theme -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0"
                            Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">

                    <Button Content="&#xE71F;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="1,0"
                            AutomationProperties.Name="Zoom out"
                            Command="{Binding Viewer.ZoomOutCommand}"
                            h:Tip.Title="Zoom out" h:Tip.Keys="Ctrl+−" />

                    <ComboBox x:Name="ZoomComboBox"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              Width="80" FontSize="12"
                              AutomationProperties.Name="Zoom level"
                              h:Tip.Title="Zoom level"
                              h:Tip.Keys="Ctrl+scroll  ·  type % then Enter"
                              Text="{Binding Viewer.Scale, Converter={StaticResource ZoomConv},
                                             UpdateSourceTrigger=LostFocus}"
                              VerticalContentAlignment="Center"
                              Margin="2,0"
                              KeyDown="ZoomInputKeyDown"
                              SelectionChanged="ZoomPresetSelected">
                        <ComboBoxItem Content="50%" />
                        <ComboBoxItem Content="75%" />
                        <ComboBoxItem Content="100%" />
                        <ComboBoxItem Content="125%" />
                        <ComboBoxItem Content="150%" />
                        <ComboBoxItem Content="200%" />
                        <ComboBoxItem Content="300%" />
                        <ComboBoxItem Content="400%" />
                    </ComboBox>

                    <Button Content="&#xE8A3;" Style="{DynamicResource Mdl2IconButtonStyle}" Margin="1,0"
                            AutomationProperties.Name="Zoom in"
                            Command="{Binding Viewer.ZoomInCommand}"
                            h:Tip.Title="Zoom in" h:Tip.Keys="Ctrl++" />
                </StackPanel>

                <!-- Window chrome buttons — flush to top-right corner, gap acts as drag region -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch" Margin="12,0,0,0">
                    <Button Content="&#xE921;" Style="{DynamicResource ChromeButtonStyle}"
                            AutomationProperties.Name="Minimize"
                            ToolTip="Minimize" Click="MinimizeClick" />
                    <Button x:Name="MaxRestoreButton"
                            Content="&#xE922;" Style="{DynamicResource ChromeButtonStyle}"
                            AutomationProperties.Name="Maximize"
                            ToolTip="Maximize" Click="MaximizeClick" />
                    <Button Content="&#xE8BB;" Style="{DynamicResource CloseButtonStyle}"
                            AutomationProperties.Name="Close"
                            ToolTip="Close" Click="CloseClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Tab Strip ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding HasTabs, Converter={StaticResource BoolToVis}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          PanningMode="HorizontalOnly">
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PdfTabViewModel}">
                            <StackPanel Orientation="Horizontal">
                                <!-- Activate button -->
                                <Button MaxWidth="220"
                                        Style="{StaticResource TabButtonStyle}"
                                        Command="{Binding DataContext.ActivateTabCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding Document.FilePath}">
                                    <TextBlock Text="{Binding TabTitle}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="180"
                                               VerticalAlignment="Center" />
                                </Button>
                                <!-- Close button -->
                                <Button Content="✕"
                                        Style="{StaticResource TabCloseButtonStyle}"
                                        Command="{Binding DataContext.CloseTabCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Close tab (Ctrl+W)" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== Update Banner ===== -->
        <Border Grid.Row="2"
                Background="#E67E22"
                Padding="12,6"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock FontSize="12" Foreground="White" VerticalAlignment="Center">
                        <Run Text="EasyPDF" />
                        <Run Text="{Binding PendingUpdate.Version, Mode=OneWay}" />
                        <Run Text="is available." />
                    </TextBlock>

                    <Button Content="Download"
                            Margin="12,0,0,0" Padding="10,3" FontSize="12"
                            Background="White" Foreground="#E67E22" BorderThickness="0" Cursor="Hand"
                            Command="{Binding DownloadUpdateCommand}"
                            Visibility="{Binding CanDownloadUpdate, Converter={StaticResource BoolToVis}}"
                            ToolTip="Download update" />

                    <Button Content="Open Page"
                            Margin="12,0,0,0" Padding="10,3" FontSize="12"
                            Background="White" Foreground="#E67E22" BorderThickness="0" Cursor="Hand"
                            Command="{Binding OpenReleasePageCommand}"
                            Visibility="{Binding UpdateCanInstall, Converter={StaticResource InvBoolToVis}}"
                            ToolTip="Open release page in browser" />

                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0"
                                Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Width="120" Height="6" Minimum="0" Maximum="100"
                                     Value="{Binding UpdateDownloadProgress, Mode=OneWay}"
                                     VerticalAlignment="Center" />
                        <TextBlock FontSize="11" Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center">
                            <Run Text="{Binding UpdateDownloadProgress, Mode=OneWay}" /><Run Text="%" />
                        </TextBlock>
                    </StackPanel>

                    <Button Content="Install &amp; Restart"
                            Margin="12,0,0,0" Padding="10,3" FontSize="12"
                            Background="White" Foreground="#E67E22" BorderThickness="0" Cursor="Hand"
                            Command="{Binding InstallUpdateCommand}"
                            Visibility="{Binding IsUpdateDownloaded, Converter={StaticResource BoolToVis}}"
                            ToolTip="Apply update and restart EasyPDF" />
                </StackPanel>

                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="24" Height="24"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand"
                        Command="{Binding DismissUpdateCommand}"
                        ToolTip="Dismiss" />
            </Grid>
        </Border>

        <!-- ===== File Changed Banner ===== -->
        <Border Grid.Row="3"
                Background="#2471A3"
                Padding="12,6"
                Visibility="{Binding FileChangedOnDisk, Converter={StaticResource BoolToVis}}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="The file was modified outside EasyPDF."
                               FontSize="12" Foreground="White" VerticalAlignment="Center" />
                    <Button Content="Reload"
                            Margin="12,0,0,0" Padding="10,3" FontSize="12"
                            Background="White" Foreground="#2471A3" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ReloadDocumentCommand}"
                            ToolTip="Reload document from disk" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="24" Height="24"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                        Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand"
                        Command="{Binding DismissFileChangedCommand}"
                        ToolTip="Dismiss" />
            </Grid>
        </Border>

        <!-- ===== Search Panel (collapsible) ===== -->
        <Border Grid.Row="4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding IsSearchPanelOpen, Converter={StaticResource BoolToVis}}">
            <Grid DataContext="{Binding Search}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search controls row -->
                <Grid Grid.Row="0" Margin="8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             AutomationProperties.Name="Search query"
                             Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             KeyDown="SearchBoxKeyDown" />

                    <ToggleButton Grid.Column="1"
                                  IsChecked="{Binding CaseSensitive}"
                                  Content="Aa"
                                  Style="{DynamicResource SearchToggleButtonStyle}"
                                  AutomationProperties.Name="Case sensitive"
                                  ToolTip="Case sensitive"
                                  Margin="4,0" />

                    <TextBlock Grid.Column="2" Margin="8,0" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                        <Run Text="{Binding CurrentResultDisplay, Mode=OneWay}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalResults, Mode=OneWay}" />
                    </TextBlock>

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="▲" Style="{DynamicResource IconButtonStyle}" Margin="2,0"
                                AutomationProperties.Name="Previous search result"
                                Command="{Binding PreviousResultCommand}"
                                h:Tip.Title="Previous match" h:Tip.Keys="Shift+F3" />
                        <Button Content="▼" Style="{DynamicResource IconButtonStyle}" Margin="2,0"
                                AutomationProperties.Name="Next search result"
                                Command="{Binding NextResultCommand}"
                                h:Tip.Title="Next match" h:Tip.Keys="F3" />
                        <Button Content="Search" Style="{DynamicResource AccentButtonStyle}" Margin="4,0"
                                Command="{Binding SearchCommand}" />
                    </StackPanel>

                    <Button Grid.Column="4" Content="✕" Width="28" Height="28"
                            Style="{DynamicResource IconButtonStyle}"
                            AutomationProperties.Name="Close search"
                            Command="{Binding DataContext.ToggleSearchCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                            h:Tip.Title="Close search" h:Tip.Keys="Esc" />
                </Grid>

                <!-- Progress bar: spans full width, visible only while searching -->
                <ProgressBar Grid.Row="1"
                             Style="{DynamicResource SearchProgressBarStyle}"
                             Minimum="0"
                             Maximum="{Binding TotalPages, Mode=OneWay}"
                             Value="{Binding SearchProgress, Mode=OneWay}"
                             Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- Row 6: reserved (annotation toolbar moved to main toolbar) -->

        <!-- ===== Main Content ===== -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn"   Width="260" MinWidth="160" />
                <ColumnDefinition x:Name="SplitterColumn"  Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}">
                <views:SidebarView DataContext="{Binding Sidebar}" />
            </Border>

            <!-- Resizable splitter — only visible when sidebar is shown -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}" />

            <!-- PDF Viewer or Welcome screen -->
            <Grid Grid.Column="2">
                <!-- Welcome / empty state -->
                <Grid Background="{DynamicResource BackgroundBrush}"
                      Visibility="{Binding HasDocument, Converter={StaticResource InvBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Hero -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,48,0,24">
                        <Image Source="pack://application:,,,/Assets/app-256.png"
                               Width="80" Height="80" HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="EasyPDF" FontSize="28" FontWeight="Light"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,4" />
                        <TextBlock Text="Open a PDF to get started"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20" />
                        <Button Content="Open PDF…"
                                Style="{DynamicResource AccentButtonStyle}"
                                Command="{Binding OpenFileCommand}"
                                HorizontalAlignment="Center" Padding="24,8" />
                    </StackPanel>

                    <!-- Recent files -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,4"
                              Width="420" HorizontalAlignment="Center"
                              Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Recent files" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Button Content="Clear" FontSize="11"
                                    HorizontalAlignment="Right" Margin="0,0,0,0"
                                    Style="{DynamicResource ToolbarButtonStyle}"
                                    Command="{Binding ClearRecentFilesCommand}"
                                    ToolTip="Clear recent files" />
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Text="No files opened yet"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding HasRecentFiles, Converter={StaticResource InvBoolToVis}}" />

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasRecentFiles, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding RecentFiles}"
                                          HorizontalAlignment="Center" Width="420"
                                          Margin="0,0,0,24">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type core:RecentFile}">
                                        <Button Style="{DynamicResource ToolbarButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.OpenRecentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel HorizontalAlignment="Left" Margin="4,2">
                                                <TextBlock Text="{Binding FileName}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding FilePath}"
                                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Main viewer -->
                <Border Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">
                    <views:PdfViewerView DataContext="{Binding Viewer}" />
                </Border>

                <!-- Loading overlay -->
                <Border Background="#AA000000"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Ellipse Stroke="White" StrokeThickness="4" Opacity="0.2" />
                            <Path Stroke="White" StrokeThickness="4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="48" Height="48" Stretch="None"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="24,2">
                                            <ArcSegment Point="2,24" Size="22,22"
                                                        IsLargeArc="True"
                                                        SweepDirection="Clockwise" />
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                                <Path.RenderTransform>
                                    <RotateTransform />
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="RenderTransform.Angle"
                                                    From="0" To="360" Duration="0:0:0.9" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Grid>
                        <TextBlock Text="Opening…" Foreground="White" FontSize="14"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="7"
                Background="{DynamicResource ToolbarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="8,0" />

                <TextBlock Grid.Column="1"
                           FontSize="11" VerticalAlignment="Center" Margin="8,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">
                    <Run Text="{Binding Viewer.ZoomPercent, Mode=OneWay}" />
                    <Run Text="  ·  " />
                    <Run Text="{Binding CurrentDocument.PageCount, Mode=OneWay}" />
                    <Run Text="pages" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
