<UserControl x:Class="EasyPDF.UI.Controls.PdfPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EasyPDF.UI.Converters"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <conv:RenderedPageToImageSourceConverter x:Key="PageConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True" />
    </UserControl.Resources>

    <Grid>
        <!-- Decoration layer: empty border carries the shadow effect.
             No children → effect pipeline only rasterizes a flat rectangle,
             never touching the page bitmap. -->
        <Border Margin="8" CornerRadius="2"
                Background="{DynamicResource SurfaceBrush}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.35" Color="Black" />
            </Border.Effect>
        </Border>

        <!-- Content layer: no Effect → Image goes directly through the GPU path,
             rendered at 1:1 logical pixels with full MuPDF quality. -->
        <Grid Margin="8">
            <Image x:Name="PageImage"
                   Stretch="None"
                   UseLayoutRounding="True"
                   Source="{Binding RenderedPage, Converter={StaticResource PageConverter}}"
                   Visibility="{Binding RenderedPage, Converter={StaticResource NullToVis}}" />

            <!-- Loading spinner shown while rendering -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsRendering, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#x231B;" FontSize="24"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Rendering…" FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Placeholder skeleton shown before first render -->
            <Border Background="{DynamicResource SurfaceAltBrush}"
                    Visibility="{Binding RenderedPage, Converter={StaticResource NullToVisInv}}">
                <TextBlock Text="{Binding DisplayNumber}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextDisabledBrush}"
                           FontSize="18" />
            </Border>

            <!-- Error overlay -->
            <Border Background="#AA880000" CornerRadius="2"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Failed to render page" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- Page number badge -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,6" Padding="8,2"
                    Background="#80000000" CornerRadius="10">
                <TextBlock Text="{Binding DisplayNumber}"
                           Foreground="White" FontSize="11" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
