<UserControl x:Class="EasyPDF.UI.Controls.PdfPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EasyPDF.UI.Converters"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True" />
        <conv:HexToColorConverter x:Key="HexToColorConverter" />
        <conv:DisplayPointsToPointCollectionConverter x:Key="PointsConverter" />
    </UserControl.Resources>

   
    <Grid Margin="8">

       
        <Border CornerRadius="2" Background="White" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.35" Color="Black" />
            </Border.Effect>
        </Border>

        <Border CornerRadius="2" Background="White" ClipToBounds="True">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.LayoutTransform>
                    <RotateTransform Angle="{Binding Rotation}" />
                </Grid.LayoutTransform>

                

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsRendering, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#x231B;" FontSize="24"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Rendering…" FontSize="11" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

               
                <Border Background="White"
                        Visibility="{Binding PageImage, Converter={StaticResource NullToVisInv}}">
                    <TextBlock Text="{Binding DisplayNumber}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextDisabledBrush}"
                               FontSize="18" />
                </Border>

                <!-- Highlights / underlines são compostos direto no bitmap via BakeHighlights
                     no PdfViewerViewModel. Nada é renderizado por overlay aqui — o data
                     AnnotationHighlights na PageViewModel segue existindo só para hit-testing
                     (HitTestAnnotation em PdfPageControl.xaml.cs). -->

                <Image x:Name="PageImage"
                       UseLayoutRounding="True"
                       RenderOptions.BitmapScalingMode="Fant"
                       Source="{Binding PageImage}"
                       Visibility="{Binding PageImage, Converter={StaticResource NullToVis}}">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Stretch" Value="None" />
                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsStale}" Value="True">
                                    <Setter Property="Stretch" Value="Uniform" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <Canvas IsHitTestVisible="False"
                        Width="{Binding BitmapWidth}"
                        Height="{Binding BitmapHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding SelectionHighlights}"
                                  IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                           Fill="#503399FF" IsHitTestVisible="False" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <Canvas IsHitTestVisible="False"
                        Width="{Binding BitmapWidth}"
                        Height="{Binding BitmapHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding SearchHighlights}"
                                  IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                           IsHitTestVisible="False">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="#60FFDD00" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Fill" Value="#80FF8C00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- Traços Ink persistidos -->
                <Canvas IsHitTestVisible="False"
                        Width="{Binding BitmapWidth}"
                        Height="{Binding BitmapHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding InkStrokes}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><Canvas IsItemsHost="True" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Polyline Points="{Binding Points, Converter={StaticResource PointsConverter}}"
                                          StrokeThickness="{Binding Thickness}"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          IsHitTestVisible="False">
                                    <Polyline.Stroke>
                                        <SolidColorBrush Color="{Binding ColorHex,
                                            Converter={StaticResource HexToColorConverter}}" />
                                    </Polyline.Stroke>
                                </Polyline>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- Canvas de ink ativo (gerenciado pelo code-behind; Polyline adicionada dinamicamente) -->
                <Canvas x:Name="LiveInkCanvas"
                        IsHitTestVisible="False"
                        Width="{Binding BitmapWidth}"
                        Height="{Binding BitmapHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True" />

                <!-- Notas de texto (sticky notes) -->
                <Canvas Width="{Binding BitmapWidth}"
                        Height="{Binding BitmapHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding NoteAnnotations}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><Canvas IsItemsHost="True" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="28" Height="28" Cursor="Hand"
                                        Tag="{Binding}"
                                        ToolTip="{Binding Content}"
                                        BorderBrush="#F59E0B" BorderThickness="1.5"
                                        Background="#FFFDE68A" CornerRadius="4">
                                    <TextBlock Text="📝" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <Border Background="#AA880000" CornerRadius="2"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Failed to render page" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
