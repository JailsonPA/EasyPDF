<UserControl x:Class="EasyPDF.UI.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPDF.Application.ViewModels;assembly=EasyPDF.Application"
             xmlns:conv="clr-namespace:EasyPDF.UI.Converters"
             xmlns:ctrl="clr-namespace:EasyPDF.UI.Controls"
             Background="{DynamicResource SidebarBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:LevelToIndentConverter x:Key="LevelToIndent" />

        <!-- Thumbnail item template — ThumbnailControl renders lazily on IsVisible=True,
             so only the thumbnails actually scrolled into view are ever rendered. -->
        <DataTemplate x:Key="ThumbnailTemplate" DataType="{x:Type vm:ThumbnailItemViewModel}">
            <Border Margin="6,4" CornerRadius="4" Cursor="Hand" BorderThickness="2"
                    AutomationProperties.Name="{Binding DisplayNumber, StringFormat='Page {0}'}"
                    AutomationProperties.HelpText="Click to navigate to this page">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" />
                </Border.InputBindings>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource ThumbnailBorderBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ThumbnailSelectedBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ctrl:ThumbnailControl
                    DataContext="{Binding}"
                    SidebarVm="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>
        </DataTemplate>

        <!-- TOC item template (recursive) -->
        <HierarchicalDataTemplate x:Key="TocTemplate"
                                  DataType="{x:Type vm:TocItemViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Title}" Cursor="Hand"
                       AutomationProperties.Name="{Binding Title}"
                       AutomationProperties.HelpText="Click to navigate to this section"
                       Padding="{Binding Level, Converter={StaticResource LevelToIndent}}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="12" Margin="2">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" />
                </TextBlock.InputBindings>
            </TextBlock>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tab bar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Height="36">
                <Button Content="Pages"
                        Command="{Binding SetTabCommand}"
                        CommandParameter="{x:Static vm:SidebarTab.Thumbnails}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.Thumbnails}">
                                    <Setter Property="Tag" Value="Active" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Contents"
                        Command="{Binding SetTabCommand}"
                        CommandParameter="{x:Static vm:SidebarTab.TableOfContents}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.TableOfContents}">
                                    <Setter Property="Tag" Value="Active" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Bookmarks"
                        Command="{Binding SetTabCommand}"
                        CommandParameter="{x:Static vm:SidebarTab.Bookmarks}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarTabButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.Bookmarks}">
                                    <Setter Property="Tag" Value="Active" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Tab content: Thumbnails -->
        <ListBox x:Name="ThumbnailList"
                 Grid.Row="1"
                 ItemsSource="{Binding Thumbnails}"
                 ItemTemplate="{StaticResource ThumbnailTemplate}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 Background="Transparent" BorderBrush="Transparent"
                 HorizontalContentAlignment="Stretch">
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.Thumbnails}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <!-- Strip ListBoxItem chrome — thumbnail selection is shown via border color in ThumbnailTemplate. -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Focusable" Value="False" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- TOC TreeView -->
        <TreeView Grid.Row="1"
                  ItemsSource="{Binding TocItems}"
                  ItemTemplate="{StaticResource TocTemplate}"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <TreeView.Style>
                <Style TargetType="TreeView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.TableOfContents}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Style>
        </TreeView>

        <!-- TOC empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="16">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.TableOfContents}" />
                                <Condition Binding="{Binding HasTocItems}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                       HorizontalAlignment="Center" Margin="0,0,0,10"
                       Foreground="{DynamicResource TextDisabledBrush}" />
            <TextBlock Text="No table of contents"
                       HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="This PDF has no embedded bookmarks or outline."
                       HorizontalAlignment="Center" FontSize="11"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextDisabledBrush}" />
        </StackPanel>

        <!-- Bookmarks empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="16">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.Bookmarks}" />
                                <Condition Binding="{Binding HasBookmarks}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="No bookmarks yet"
                       HorizontalAlignment="Center"
                       FontSize="12" TextAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock Text="Press Ctrl+B to add a bookmark"
                       HorizontalAlignment="Center"
                       FontSize="11" TextAlignment="Center" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Bookmarks ListBox -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Bookmarks}"
                 Background="Transparent"
                 BorderBrush="Transparent">
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActiveTab}" Value="{x:Static vm:SidebarTab.Bookmarks}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:BookmarkItemViewModel}">
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Cursor="Hand">
                            <StackPanel.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding NavigateCommand}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="{Binding Title}" FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding DisplayNumber, StringFormat='Page {0}'}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="20" Height="20"
                                Style="{DynamicResource IconButtonStyle}"
                                FontSize="10"
                                AutomationProperties.Name="{Binding Title, StringFormat='Remove bookmark {0}'}"
                                Command="{Binding DeleteCommand}"
                                ToolTip="Remove bookmark" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
