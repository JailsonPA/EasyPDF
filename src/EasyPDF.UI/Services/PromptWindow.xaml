<Window x:Class="EasyPDF.UI.Services.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="380" Height="160"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        KeyDown="OnKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowChromeBrush}"
              MouseLeftButtonDown="OnTitleBarMouseDown">
            <TextBlock x:Name="TitleText"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource WindowChromeTextBrush}"
                       VerticalAlignment="Center" Margin="12,0" />
            <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                    Style="{DynamicResource ChromeButtonStyle}"
                    Click="Cancel_Click" />
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="HintText" Grid.Row="0"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" />

            <TextBox x:Name="InputBox" Grid.Row="2" FontSize="13" />

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="75" Click="Cancel_Click" Margin="0,0,8,0"
                        Style="{DynamicResource ToolbarButtonStyle}" />
                <Button Content="OK" Width="75" Click="OK_Click"
                        Style="{DynamicResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
