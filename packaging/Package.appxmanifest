<?xml version="1.0" encoding="utf-8"?>
<!--
  Package.appxmanifest — EasyPDF MSIX manifest (source copy, kept in version control).
  The publish script copies this file into the publish folder as "AppxManifest.xml".

  Publisher must match the CN of your signing certificate exactly.
  Default dev cert (created by scripts/publish-msix.ps1): CN=EasyPDF Dev
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <Identity
    Name="JailsonPA.EasyPDF"
    Publisher="CN=EasyPDF Dev"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>EasyPDF</DisplayName>
    <PublisherDisplayName>JailsonPA</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!-- Windows 10 2004 (19041) or later; tested up to Windows 11 24H2 -->
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.19041.0"
                        MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App"
                 Executable="EasyPDF.exe"
                 EntryPoint="Windows.FullTrustApplication">

      <uap:VisualElements
        DisplayName="EasyPDF"
        Description="A fast, clean PDF viewer for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" ShortName="EasyPDF" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>

      <Extensions>
        <!-- Handle .pdf files: EasyPDF appears in "Open with" and can be set as default viewer -->
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="easypdf-pdf">
            <uap:SupportedFileTypes>
              <uap:FileType ContentType="application/pdf">.pdf</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>PDF Document</uap:DisplayName>
            <uap:Logo>Assets\Square44x44Logo.png</uap:Logo>
            <uap:InfoTip>Open with EasyPDF</uap:InfoTip>
          </uap:FileTypeAssociation>
        </uap:Extension>

        <!-- Command-line alias: `easypdf document.pdf` from any terminal -->
        <uap3:Extension Category="windows.appExecutionAlias">
          <uap3:AppExecutionAlias>
            <uap3:ExecutionAlias Alias="easypdf.exe" />
          </uap3:AppExecutionAlias>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Full-trust required for WPF Desktop Bridge apps. -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
